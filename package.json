{
  "name": "preventivi-smart-pro",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "description": "Verifica in pochi secondi se il preventivo dell'artigiano è onesto. App italiana di analisi preventivi con dati di mercato regionali.",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "esbuild",
      "protobufjs"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude=e2e",
    "test:unit": "vitest run --exclude=e2e --exclude=src/test/firestore-rules.test.ts",
    "test:firestore": "firebase emulators:exec --only firestore \"vitest run src/test/firestore-rules.test.ts\"",
    "test:e2e": "playwright test",
    "test:all": "pnpm test:unit && pnpm test:firestore && pnpm test:e2e",
    "predeploy": "pnpm build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
