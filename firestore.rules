/**
 * Preventivi-Smart Pro — Firestore Security Rules v2.0
 * - Schema allineato a quote-manager.js
 * - isAdmin() senza ricorsione (allow get sulla collection admins)
 * - Rate limiting tramite query lato client + sanity-check sul doc
 * - Validazione tipi e dimensioni stringhe
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPERS =====

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Lettura admins consentita: nessuna ricorsione.
    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // String guard: presente, stringa, non vuota, lunghezza max
    function isString(v, maxLen) {
      return v is string && v.size() > 0 && v.size() <= maxLen;
    }

    function isPositiveNumber(num) {
      return num is number && num > 0;
    }

    // Schema reale usato da quote-manager.js
    function isValidQuote(d) {
      return d.keys().hasAll([
              'uid','numero','data','cliente','servizi','totale','createdAt','updatedAt'
            ])
        && d.uid is string
        && d.numero is number && d.numero > 0
        && isString(d.data, 32)
        && isString(d.cliente, 200)
        && d.servizi is list && d.servizi.size() > 0 && d.servizi.size() <= 100
        && isPositiveNumber(d.totale) && d.totale < 10000000
        && d.createdAt is number
        && d.updatedAt is number
        && (!('note' in d) || (d.note is string && d.note.size() <= 5000));
    }

    // ===== quotes =====
    // Nota: usiamo `resource.data.get('uid', '')` per evitare errori su
    // documenti legacy senza campo uid (regola fail-safe). Admin sempre OK.
    match /quotes/{document=**} {
      allow read:   if isAdmin()
                    || isOwner(resource.data.get('uid', ''));
      allow create: if isAuthenticated()
                    && isValidQuote(request.resource.data)
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin()
                    || (isOwner(resource.data.get('uid', ''))
                        && request.resource.data.uid == resource.data.uid
                        && isValidQuote(request.resource.data));
      allow delete: if isAdmin()
                    || isOwner(resource.data.get('uid', ''));
    }

    // ===== users =====
    match /users/{uid} {
      allow read:   if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated()
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && isString(request.resource.data.email, 320);
      allow update: if isAuthenticated()
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid;
      allow delete: if isAuthenticated() && request.auth.uid == uid;
    }

    // ===== analytics (aggregati pubblici) =====
    match /analytics/{document=**} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ===== admins (solo lettura agli admin, scrittura nessuno via client) =====
    match /admins/{uid} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ===== feedback =====
    match /feedback/{document=**} {
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid
                    && isString(request.resource.data.message, 5000);
      allow read:   if isAdmin();
      allow delete: if isAdmin();
      allow update: if false;
    }

    // ===== api-keys (mai dal client) =====
    match /api-keys/{document=**} {
      allow read, write: if false;
    }

    // ===== default deny =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
